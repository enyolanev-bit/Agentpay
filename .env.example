# Local simulation quickstart. No real payment is attempted when SIMULATE_PAYMENTS=1.
MOLLIE_API_KEY=test_dummy

# Local base URL used in generated status, undo, and confirm links.
# For Mollie test mode with public webhooks, replace this with an HTTPS ngrok URL.
BASE_URL=http://localhost:3000

# Port local du serveur Express
PORT=3000

# Persistence locale du MVP. Utiliser :memory: pour des tests jetables.
AGENTPAY_DATA_FILE=data/agentpay.json

# Modes rapides de demo locale
SIMULATE_PAYMENTS=1
VERIFIER_MODE=heuristic
DECIDER_MODE=fallback
NODE_ENV=development
LOG_LEVEL=debug
