# Cle API Mollie, environnement test (sandbox). A recuperer dans ton dashboard Mollie.
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL publique fournie par ngrok au lancement. Doit etre en https.
# Exemple : https://a1b2-c3d4.ngrok-free.app
BASE_URL=https://xxxx.ngrok-free.app

# Port local du serveur Express
PORT=3000

# Persistence locale du MVP. Utiliser :memory: pour des tests jetables.
AGENTPAY_DATA_FILE=data/agentpay.json

# Modes rapides de demo locale
SIMULATE_PAYMENTS=1
VERIFIER_MODE=heuristic
DECIDER_MODE=fallback
NODE_ENV=development
LOG_LEVEL=debug
