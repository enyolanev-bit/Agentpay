{
  "name": "agentpay",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Trust layer for AI agent payments: reversible intents, deterministic policy, audit, and Mollie rails.",
  "exports": {
    ".": "./sdk/client.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "mcp": "node mcp/server.js",
    "example:agent": "node examples/node-agent/agent.js",
    "example:prepare-payment": "node examples/node-agent/prepare-payment.js",
    "audit:publish": "node scripts/audit-publication.js",
    "check": "find . -name '*.js' -not -path './node_modules/*' -print0 | xargs -0 -n1 node --check",
    "test": "node --test"
  },
  "dependencies": {
    "@mollie/api-client": "^4.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  }
}
